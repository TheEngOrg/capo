#!/usr/bin/env bash
# teo-set-session-marker — write teo-session-active marker with UTC timestamp
#
# Usage: teo-set-session-marker [--json]
#
# Performs both mkdir -p and timestamp write internally so the caller
# issues a single argument-free Bash call with no shell metacharacters.
#
# Path resolution: SCRIPT_DIR → PROJECT_ROOT via cd dirname/../../
# Override: set TEO_PROJECT_ROOT env var (used by tests for tmpdir isolation)
#
# Exit codes:
#   0  success
#   1  bad argument, mkdir failure, or write failure
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="${TEO_PROJECT_ROOT:-$(cd "$SCRIPT_DIR/../.." && pwd)}"
TRACES_DIR="$PROJECT_ROOT/.claude/memory/traces"
MARKER="$TRACES_DIR/teo-session-active"

# Parse optional --json flag; reject any other argument
EMIT_JSON=false
for arg in "$@"; do
    case "$arg" in
        --json) EMIT_JSON=true ;;
        *)
            printf 'USAGE: teo-set-session-marker [--json]\n' >&2
            exit 1
            ;;
    esac
done

if ! mkdir -p "$TRACES_DIR"; then
    printf 'ERROR: teo-set-session-marker: cannot create %s\n' "$TRACES_DIR" >&2
    exit 1
fi

TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
printf '%s\n' "$TIMESTAMP" > "$MARKER"

if [[ "$EMIT_JSON" == "true" ]]; then
    printf '{"timestamp":"%s","marker":"%s"}\n' "$TIMESTAMP" "$MARKER"
fi

exit 0
