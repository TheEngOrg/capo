{
  "name": "@the-eng-org/teo",
  "version": "0.1.0",
  "description": "TEO v5 — deterministic multi-agent orchestration for Claude Code",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "bundle": "tsc --noEmit && node esbuild.config.mjs",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.config.{ts,js}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.config.{ts,js}\" \"scripts/**/*.mjs\"",
    "check-lockfile": "node scripts/check-lockfile.mjs",
    "e2e": "bash scripts/e2e-headless.sh",
    "verify:plugin": "bash scripts/verify-plugin-install.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,js,mjs}": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.25.12",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
