#!/usr/bin/env bash
# teo-find — Safe wrapper around `find` with depth cap and blocked destructive flags
#
# Usage: .claude/scripts/teo-find <root> [find-opts]
#
# Blocked flags: -exec, -execdir, -delete, -ok
# Default -maxdepth: 4 (injected if absent)
# Maximum -maxdepth: 10 (hard ceiling; reject anything higher)
#
# macOS/Linux compatible.
#
# Exit codes:
#   0 = find succeeded (or no matches)
#   1 = validation error
#   other = find exit code (pass-through)

set -euo pipefail

MAXDEPTH_DEFAULT=4
MAXDEPTH_CAP=10

# [1] Arg count guard
if [[ $# -lt 1 ]]; then
    echo "error: usage: teo-find <root> [find-opts]" >&2
    exit 1
fi

# [2] Blocked destructive/execution flags — scan all args
for arg in "$@"; do
    case "$arg" in
        -exec|-execdir|-ok)
            echo "error: invalid flag — -exec/-execdir/-ok are blocked in teo-find: $arg" >&2
            exit 1
            ;;
        -delete)
            echo "error: invalid flag — -delete is blocked in teo-find: $arg" >&2
            exit 1
            ;;
    esac
done

# [3] Check for user-supplied -maxdepth and enforce cap
HAS_MAXDEPTH=0
SUPPLIED_DEPTH=0
PREV_ARG=""
for arg in "$@"; do
    if [[ "$PREV_ARG" == "-maxdepth" ]]; then
        # Validate that depth is numeric
        if ! [[ "$arg" =~ ^[0-9]+$ ]]; then
            echo "error: invalid -maxdepth value — must be a non-negative integer: $arg" >&2
            exit 1
        fi
        SUPPLIED_DEPTH="$arg"
        HAS_MAXDEPTH=1
        if [[ "$SUPPLIED_DEPTH" -gt "$MAXDEPTH_CAP" ]]; then
            echo "error: invalid -maxdepth $SUPPLIED_DEPTH — exceeds hard ceiling of $MAXDEPTH_CAP" >&2
            exit 1
        fi
    fi
    PREV_ARG="$arg"
done

# [4] Build args: inject -maxdepth if not present
if [[ "$HAS_MAXDEPTH" -eq 0 ]]; then
    # Inject default maxdepth after the root (first positional arg)
    ROOT="${1}"
    shift
    exec find "$ROOT" -maxdepth "$MAXDEPTH_DEFAULT" "$@"
else
    exec find "$@"
fi
