{
  "name": "teo",
  "version": "5.0.0",
  "description": "TEO 5 — deterministic team orchestration for Claude Code",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:darwin": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/teo-darwin-arm64",
    "build:linux": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/teo-linux-x64",
    "lint": "bunx biome check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.0.0",
    "typescript": "5.4.5",
    "vitest": "^3.2.6"
  }
}
