#!/usr/bin/env bash
# teo-grep-r — Safe recursive grep wrapper with root allow-list enforcement
#
# Usage: .claude/scripts/teo-grep-r <pattern> <root>
#
# Allowed roots (OQ1 — locked by user): $HOME, /tmp, $PROJECT_ROOT
# Pattern injection guard: same metacharacter regex as other wrappers.
# Fixed flags: grep -rI (recursive, binary files skipped).
#
# Exit codes:
#   0 = match(es) found
#   1 = no matches OR validation error
#   other = grep exit code (pass-through)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

# [1] Arg count guard
if [[ $# -ne 2 ]]; then
    echo "error: usage: teo-grep-r <pattern> <root>" >&2
    exit 1
fi

PATTERN="${1}"
ROOT="${2}"

# [2] Pattern injection guard — reject shell metacharacters
if [[ "$PATTERN" =~ [';|&$`(){}><'] ]]; then
    echo "error: invalid argument — shell metacharacter detected in pattern: $PATTERN" >&2
    exit 1
fi

# [3] Root path: dot-dot guard
if [[ "$ROOT" == *".."* ]]; then
    # Resolve to check for traversal to disallowed location
    RESOLVED_ROOT=""
    if command -v realpath >/dev/null; then
        RESOLVED_ROOT="$(realpath "$ROOT" 2>/dev/null || echo "")"
    fi
    if [[ -z "$RESOLVED_ROOT" ]]; then
        echo "error: invalid root — path traversal (..) detected and could not be resolved: $ROOT" >&2
        echo "  blocked: root must be under \$HOME, /tmp, or project root" >&2
        exit 1
    fi
    ROOT="$RESOLVED_ROOT"
fi

# [4] Root injection guard — reject shell metacharacters
if [[ "$ROOT" =~ [';|&$`(){}><'] ]]; then
    echo "error: invalid argument — shell metacharacter detected in root: $ROOT" >&2
    exit 1
fi

# [5] Resolve root for allow-list check
RESOLVED_ROOT="$ROOT"
if command -v realpath >/dev/null; then
    RESOLVED_ROOT="$(realpath "$ROOT" 2>/dev/null || echo "$ROOT")"
fi

# [6] Root allow-list check: must be under $HOME, /tmp, $TMPDIR, or $PROJECT_ROOT
# On macOS /tmp is a symlink to /private/tmp; $TMPDIR is /var/folders/... (-> /private/var/folders/...).
# Accept both the literal and canonical forms so tests using $BATS_TMPDIR work correctly.
TMPDIR_CANONICAL="${TMPDIR:-/tmp}"
if command -v realpath >/dev/null; then
    TMPDIR_CANONICAL="$(realpath "$TMPDIR_CANONICAL" 2>/dev/null || echo "$TMPDIR_CANONICAL")"
fi

ALLOWED=0
if [[ "$RESOLVED_ROOT" == "$HOME"/* || "$RESOLVED_ROOT" == "$HOME" ]]; then
    ALLOWED=1
elif [[ "$RESOLVED_ROOT" == "/tmp"/* || "$RESOLVED_ROOT" == "/tmp" ]]; then
    ALLOWED=1
elif [[ "$RESOLVED_ROOT" == "/private/tmp"/* || "$RESOLVED_ROOT" == "/private/tmp" ]]; then
    ALLOWED=1
elif [[ -n "$TMPDIR_CANONICAL" && ( "$RESOLVED_ROOT" == "$TMPDIR_CANONICAL"/* || "$RESOLVED_ROOT" == "$TMPDIR_CANONICAL" ) ]]; then
    ALLOWED=1
elif [[ "$RESOLVED_ROOT" == "$PROJECT_ROOT"/* || "$RESOLVED_ROOT" == "$PROJECT_ROOT" ]]; then
    ALLOWED=1
fi

if [[ "$ALLOWED" -eq 0 ]]; then
    echo "error: invalid root — path is outside allowed root set: $ROOT" >&2
    echo "  resolved: $RESOLVED_ROOT" >&2
    echo "  allowed:  \$HOME ($HOME), /tmp, project root ($PROJECT_ROOT)" >&2
    exit 1
fi

# [7] Execute with fixed flags
exec grep -rI "$PATTERN" "$ROOT"
