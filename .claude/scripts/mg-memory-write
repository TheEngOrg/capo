#!/usr/bin/env bash
# ============================================================================
# mg-memory-write — TEO Memory JSON Field Update Tool
# ============================================================================
# Sets or upserts a field in an existing .claude/memory/ JSON file.
# Uses dot-notation path (e.g., a.b.c) for nested access.
#
# USAGE
#   mg-memory-write --target <rel-path> --field <path> --value <json>
#   mg-memory-write --target <rel-path> --field <path> --value-string <str>
#   mg-memory-write --help | -h
#
# OPTIONS
#   --target <path>         Project-relative path under .claude/memory/
#   --field <dot-path>      Dot-notation path (e.g., prerequisites.foo.met)
#   --value <json>          Raw JSON value (false, true, 42, "str")
#   --value-string <str>    String value (auto-quoted)
#   --project-root <path>   Override project root
#
# SECURITY
#   Path gate fires BEFORE any bypass check.
#   Target must be under .claude/memory/ — refuses scripts/hooks/settings.json.
#   Rejects: absolute paths, .. traversal, ~ tilde, $VAR, null bytes, symlinks.
#   Writes via flock + mktemp + mv (mirrors teo-apply-edit atomicity).
#   Bypass token: teo-ae-PID-EPOCH format (same surface as teo-apply-edit).
#   EXIT trap unsets bypass token on any exit path.
#   Every applied/refused outcome is written to edit-audit-DATE.json.
#
# EXIT CODES
#   0  Applied
#   1  Refused
#   2  Usage error
# ============================================================================

set -uo pipefail

SCRIPT_NAME="mg-memory-write"

# Bypass token (mirrors teo-apply-edit; path gate fires BEFORE this matters)
TEO_APPLY_EDIT_BYPASS="teo-ae-$$-$(date +%s)"
export TEO_APPLY_EDIT_BYPASS
_MG_WRITE_TMPFILES=()
trap 'unset TEO_APPLY_EDIT_BYPASS; for _f in "${_MG_WRITE_TMPFILES[@]:-}"; do rm -f "$_f" 2>/dev/null || true; done' EXIT

# Infrastructure
HAS_JQ=true
HAS_FLOCK=true
if ! command -v jq > /dev/null 2>&1; then
  printf 'ERROR: jq is required\n' >&2; exit 1
fi
if ! command -v flock > /dev/null 2>&1; then
  HAS_FLOCK=false
  printf 'WARN: flock not available — writing without lock\n' >&2
fi

EXECUTION_ID="$(date +%s)-$$"
get_timestamp() { date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%SZ'; }
get_date_suffix() { date -u '+%Y-%m-%d' 2>/dev/null || date '+%Y-%m-%d'; }

usage() {
  printf 'Usage: %s --target <path> --field <dot-path> (--value <json>|--value-string <str>)\n' "$SCRIPT_NAME"
  printf 'Set/upsert a JSON field in a .claude/memory/ file.\n'
  printf 'Options:\n'
  printf '  --target <path>         Relative path under .claude/memory/\n'
  printf '  --field <dot-path>      Dot-notation path (e.g., a.b.c)\n'
  printf '  --value <json>          Raw JSON value\n'
  printf '  --value-string <str>    String value (auto-quoted)\n'
  printf '  --project-root <path>   Override project root\n'
  printf '  --help, -h              Show help\n'
}

# Argument parsing
TARGET=""
FIELD_PATH=""
VALUE_JSON=""
VALUE_STRING=""
VALUE_MODE=""
PROJECT_ROOT_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    --target)
      [[ $# -lt 2 ]] && { printf 'ERROR: --target requires an argument\n' >&2; exit 2; }
      TARGET="$2"; shift 2 ;;
    --field)
      [[ $# -lt 2 ]] && { printf 'ERROR: --field requires an argument\n' >&2; exit 2; }
      FIELD_PATH="$2"; shift 2 ;;
    --value)
      [[ $# -lt 2 ]] && { printf 'ERROR: --value requires an argument\n' >&2; exit 2; }
      VALUE_JSON="$2"; VALUE_MODE="json"; shift 2 ;;
    --value-string)
      [[ $# -lt 2 ]] && { printf 'ERROR: --value-string requires an argument\n' >&2; exit 2; }
      VALUE_STRING="$2"; VALUE_MODE="string"; shift 2 ;;
    --project-root)
      [[ $# -lt 2 ]] && { printf 'ERROR: --project-root requires an argument\n' >&2; exit 2; }
      PROJECT_ROOT_ARG="$2"; shift 2 ;;
    -*) printf 'ERROR: unrecognized flag: %s\n' "$1" >&2; exit 2 ;;
    *) printf 'ERROR: unexpected argument: %s\n' "$1" >&2; exit 2 ;;
  esac
done

[[ -z "$TARGET" ]] && { printf 'ERROR: --target is required\n' >&2; exit 2; }
[[ -z "$FIELD_PATH" ]] && { printf 'ERROR: --field is required\n' >&2; exit 2; }
[[ -z "$VALUE_MODE" ]] && { printf 'ERROR: --value or --value-string is required\n' >&2; exit 2; }

# Project root resolution
if [[ -n "$PROJECT_ROOT_ARG" ]]; then
  PROJECT_ROOT="$PROJECT_ROOT_ARG"
elif [[ -n "${TEO_PROJECT_ROOT:-}" ]]; then
  PROJECT_ROOT="$TEO_PROJECT_ROOT"
elif command -v git > /dev/null 2>&1; then
  PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || printf '%s' "$PWD")"
else
  PROJECT_ROOT="$PWD"
fi

[[ -n "${TEO_AUDIT_DIR:-}" ]] && AUDIT_DIR="$TEO_AUDIT_DIR" || AUDIT_DIR="${PROJECT_ROOT}/.claude/memory/traces"

# Audit helpers
atomic_json_append() {
  local log_file="$1" entry_json="$2" lock_file tmp_file
  lock_file="${log_file}.lock"
  tmp_file="$(mktemp "${log_file}.tmp.XXXXXX")" || { printf 'WARN: audit temp failed\n' >&2; return 0; }
  _MG_WRITE_TMPFILES+=("$tmp_file")
  local existing="[]"
  if [[ -s "$log_file" ]] && jq empty "$log_file" > /dev/null 2>&1; then
    existing="$(cat "$log_file")"
  fi
  if [[ "$HAS_FLOCK" == "true" ]]; then
    (flock -x -w 10 9 2>/dev/null || true
     printf '%s' "$existing" | jq --argjson e "$entry_json" '. + [$e]' > "$tmp_file" 2>/dev/null && mv "$tmp_file" "$log_file"
    ) 9>"$lock_file"
    rm -f "$lock_file" 2>/dev/null || true
  else
    printf '%s' "$existing" | jq --argjson e "$entry_json" '. + [$e]' > "$tmp_file" 2>/dev/null && mv "$tmp_file" "$log_file"
  fi
}

write_audit() {
  local verdict="$1" reason="${2:-}"
  local log_file="${AUDIT_DIR}/edit-audit-$(get_date_suffix).json"
  mkdir -p "$AUDIT_DIR" 2>/dev/null || true
  local entry
  if [[ "$verdict" == "refused" ]]; then
    entry="$(jq -n --arg ei "$EXECUTION_ID" --arg ag "${AGENT_IDENTITY_TOKEN:-unknown}" --arg p "$TARGET" --arg op 'json-field-update' --arg v "$verdict" --arg r "$reason" --arg ts "$(get_timestamp)" '{execution_id:$ei,agent:$ag,path:$p,operation:$op,verdict:$v,refusal_reason:$r,timestamp:$ts}' 2>/dev/null)" || return 0
  else
    entry="$(jq -n --arg ei "$EXECUTION_ID" --arg ag "${AGENT_IDENTITY_TOKEN:-unknown}" --arg p "$TARGET" --arg op 'json-field-update' --arg v "$verdict" --arg ts "$(get_timestamp)" '{execution_id:$ei,agent:$ag,path:$p,operation:$op,verdict:$v,timestamp:$ts}' 2>/dev/null)" || return 0
  fi
  [[ -n "$entry" ]] && atomic_json_append "$log_file" "$entry"
}

# ── PATH GATE (before bypass) ───────────────────────────────────────────────
[[ -z "$TARGET" ]] && { printf 'ERROR: empty target path\n' >&2; write_audit "refused" "empty-path"; exit 1; }
# null byte check
if printf '%s' "$TARGET" | grep -qP '\x00' 2>/dev/null; then
  printf 'ERROR: null byte in path\n' >&2; write_audit "refused" "null-byte-in-path"; exit 1
fi
# tilde
[[ "$TARGET" == "~"* ]] && { printf 'ERROR: tilde expansion not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "tilde-expansion"; exit 1; }
# $VAR
[[ "$TARGET" == '$'* ]] && { printf 'ERROR: env-var expansion not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "env-var-expansion"; exit 1; }
# absolute
[[ "$TARGET" == /* ]] && { printf 'ERROR: absolute path not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "absolute-path"; exit 1; }
# traversal
if [[ "$TARGET" == *"/../"* ]] || [[ "$TARGET" == *"/.." ]] || [[ "$TARGET" == ".."* ]] || printf '%s' "$TARGET" | grep -qE '(^|/)\.\.(/|$)'; then
  printf 'ERROR: path traversal detected: %s\n' "$TARGET" >&2; write_audit "refused" "path-traversal"; exit 1
fi
# memory allowlist
if [[ "$TARGET" != ".claude/memory/"* ]] && [[ "$TARGET" != ".claude/memory" ]]; then
  printf 'ERROR: path not in memory allowlist: %s\n' "$TARGET" >&2; write_audit "refused" "not-in-memory-allowlist"; exit 1
fi

TARGET_FULL="${PROJECT_ROOT}/${TARGET}"
# symlink on target
[[ -L "$TARGET_FULL" ]] && { printf 'ERROR: target is a symlink: %s\n' "$TARGET" >&2; write_audit "refused" "symlink-refused"; exit 1; }
# symlinks in path components
_cp="$TARGET"
while [[ "$_cp" == */* ]]; do
  [[ -L "${PROJECT_ROOT}/${_cp}" ]] && { printf 'ERROR: symlink in path: %s\n' "$TARGET" >&2; write_audit "refused" "symlink-in-path"; exit 1; }
  _cp="${_cp%/*}"
done

# File existence
[[ ! -f "$TARGET_FULL" ]] && { printf 'ERROR: file not found: %s\n' "$TARGET" >&2; write_audit "refused" "file-not-found"; exit 1; }
# JSON validity
jq empty "$TARGET_FULL" > /dev/null 2>&1 || { printf 'ERROR: target is not valid JSON: %s\n' "$TARGET" >&2; write_audit "refused" "invalid-json-target"; exit 1; }

# Build jq path array from dot-notation
JQ_PATH_ARRAY="$(printf '%s' "$FIELD_PATH" | jq -R 'split(".")' 2>/dev/null)" || { printf 'ERROR: invalid field path: %s\n' "$FIELD_PATH" >&2; write_audit "refused" "invalid-field-path"; exit 1; }
[[ -z "$JQ_PATH_ARRAY" ]] && { printf 'ERROR: empty field path\n' >&2; write_audit "refused" "invalid-field-path"; exit 1; }

if [[ "$VALUE_MODE" == "string" ]]; then
  NEW_JSON="$(jq --argjson pa "$JQ_PATH_ARRAY" --arg sv "$VALUE_STRING" 'setpath($pa; $sv)' "$TARGET_FULL" 2>/dev/null)" || { printf 'ERROR: setpath failed\n' >&2; write_audit "refused" "jq-setpath-failed"; exit 1; }
else
  printf '%s' "$VALUE_JSON" | jq empty > /dev/null 2>&1 || { printf 'ERROR: --value is not valid JSON: %s\n' "$VALUE_JSON" >&2; write_audit "refused" "invalid-json-value"; exit 1; }
  NEW_JSON="$(jq --argjson pa "$JQ_PATH_ARRAY" --argjson nv "$VALUE_JSON" 'setpath($pa; $nv)' "$TARGET_FULL" 2>/dev/null)" || { printf 'ERROR: setpath failed\n' >&2; write_audit "refused" "jq-setpath-failed"; exit 1; }
fi

printf '%s' "$NEW_JSON" | jq empty > /dev/null 2>&1 || { printf 'ERROR: result is not valid JSON\n' >&2; write_audit "refused" "result-not-valid-json"; exit 1; }

# Atomic write
LOCK_FILE="${TARGET_FULL}.teo-mw.lock"
TMP_FILE=""
if [[ "$HAS_FLOCK" == "true" ]]; then
  TMP_FILE="$(mktemp "${TARGET_FULL}.teo-mw.tmp.XXXXXX" 2>/dev/null)" || { printf '%s\n' "$NEW_JSON" > "$TARGET_FULL"; write_audit "applied"; exit 0; }
  _MG_WRITE_TMPFILES+=("$TMP_FILE")
  (flock -x -w 10 9 2>/dev/null || printf 'WARN: flock timeout\n' >&2
   printf '%s\n' "$NEW_JSON" > "$TMP_FILE"
   mv "$TMP_FILE" "$TARGET_FULL"
  ) 9>"$LOCK_FILE"
  _SUBSHELL_RC=$?
  rm -f "$LOCK_FILE" 2>/dev/null || true
  if [[ "$_SUBSHELL_RC" -ne 0 ]]; then write_audit "refused" "atomic-write-failed"; exit 1; fi
else
  printf 'WARN: flock not available — writing without lock\n' >&2
  TMP_FILE="$(mktemp "${TARGET_FULL}.teo-mw.tmp.XXXXXX" 2>/dev/null)" || true
  if [[ -n "$TMP_FILE" ]]; then
    _MG_WRITE_TMPFILES+=("$TMP_FILE")
    printf '%s\n' "$NEW_JSON" > "$TMP_FILE"
    mv "$TMP_FILE" "$TARGET_FULL"
  else
    printf '%s\n' "$NEW_JSON" > "$TARGET_FULL"
  fi
fi

write_audit "applied"
exit 0
