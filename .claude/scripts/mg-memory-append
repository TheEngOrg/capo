#!/usr/bin/env bash
# ============================================================================
# mg-memory-append — TEO Memory MD Append Tool
# ============================================================================
# Appends a line or block to an existing .claude/memory/ Markdown file.
# Handles EOL normalization, empty files, and atomicity.
#
# USAGE
#   mg-memory-append --target <rel-path> --content <text>
#   mg-memory-append --target <rel-path> --content-file <path>
#   mg-memory-append --help | -h
#
# OPTIONS
#   --target <path>         Project-relative path under .claude/memory/
#   --content <text>        Text to append (literal; newlines via \n in $'...')
#   --content-file <path>   Read content from this file
#   --project-root <path>   Override project root
#
# EOL HANDLING
#   If the file ends with \n, content is appended without extra blank line.
#   If the file does not end with \n, a newline is inserted before content.
#   Empty file: content is written as-is.
#
# SECURITY
#   Path gate fires BEFORE any bypass check.
#   Target must be under .claude/memory/.
#   Rejects: absolute, traversal, tilde, $VAR, null bytes, symlinks.
#   Writes via flock + mktemp + mv.
#   EXIT trap unsets bypass token.
#   Every outcome audited to edit-audit-DATE.json.
#
# EXIT CODES
#   0  Applied
#   1  Refused
#   2  Usage error
# ============================================================================

set -uo pipefail

SCRIPT_NAME="mg-memory-append"

TEO_APPLY_EDIT_BYPASS="teo-ae-$$-$(date +%s)"
export TEO_APPLY_EDIT_BYPASS
_MG_APP_TMPFILES=()
trap 'unset TEO_APPLY_EDIT_BYPASS; for _f in "${_MG_APP_TMPFILES[@]:-}"; do rm -f "$_f" 2>/dev/null || true; done' EXIT

HAS_JQ=true
HAS_FLOCK=true
if ! command -v jq > /dev/null 2>&1; then
  printf 'ERROR: jq is required\n' >&2; exit 1
fi
if ! command -v flock > /dev/null 2>&1; then
  HAS_FLOCK=false
  printf 'WARN: flock not available — writing without lock\n' >&2
fi

EXECUTION_ID="$(date +%s)-$$"
get_timestamp() { date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%SZ'; }
get_date_suffix() { date -u '+%Y-%m-%d' 2>/dev/null || date '+%Y-%m-%d'; }

usage() {
  printf 'Usage: %s --target <path> (--content <text>|--content-file <path>)\n' "$SCRIPT_NAME"
  printf 'Append content to a .claude/memory/ Markdown file.\n'
  printf 'Options:\n'
  printf '  --target <path>         Relative path under .claude/memory/\n'
  printf '  --content <text>        Text to append\n'
  printf '  --content-file <path>   Read content from file\n'
  printf '  --project-root <path>   Override project root\n'
  printf '  --help, -h              Show help\n'
}

TARGET=""
CONTENT=""
CONTENT_FILE=""
CONTENT_MODE=""
PROJECT_ROOT_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    --target)
      [[ $# -lt 2 ]] && { printf 'ERROR: --target requires an argument\n' >&2; exit 2; }
      TARGET="$2"; shift 2 ;;
    --content)
      [[ $# -lt 2 ]] && { printf 'ERROR: --content requires an argument\n' >&2; exit 2; }
      CONTENT="$2"; CONTENT_MODE="inline"; shift 2 ;;
    --content-file)
      [[ $# -lt 2 ]] && { printf 'ERROR: --content-file requires an argument\n' >&2; exit 2; }
      CONTENT_FILE="$2"; CONTENT_MODE="file"; shift 2 ;;
    --project-root)
      [[ $# -lt 2 ]] && { printf 'ERROR: --project-root requires an argument\n' >&2; exit 2; }
      PROJECT_ROOT_ARG="$2"; shift 2 ;;
    -*) printf 'ERROR: unrecognized flag: %s\n' "$1" >&2; exit 2 ;;
    *) printf 'ERROR: unexpected argument: %s\n' "$1" >&2; exit 2 ;;
  esac
done

[[ -z "$TARGET" ]] && { printf 'ERROR: --target is required\n' >&2; exit 2; }
[[ -z "$CONTENT_MODE" ]] && { printf 'ERROR: --content or --content-file is required\n' >&2; exit 2; }

if [[ -n "$PROJECT_ROOT_ARG" ]]; then
  PROJECT_ROOT="$PROJECT_ROOT_ARG"
elif [[ -n "${TEO_PROJECT_ROOT:-}" ]]; then
  PROJECT_ROOT="$TEO_PROJECT_ROOT"
elif command -v git > /dev/null 2>&1; then
  PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || printf '%s' "$PWD")"
else
  PROJECT_ROOT="$PWD"
fi

[[ -n "${TEO_AUDIT_DIR:-}" ]] && AUDIT_DIR="$TEO_AUDIT_DIR" || AUDIT_DIR="${PROJECT_ROOT}/.claude/memory/traces"

atomic_json_append() {
  local log_file="$1" entry_json="$2" lock_file tmp_file
  lock_file="${log_file}.lock"
  tmp_file="$(mktemp "${log_file}.tmp.XXXXXX")" || { printf 'WARN: audit temp failed\n' >&2; return 0; }
  _MG_APP_TMPFILES+=("$tmp_file")
  local existing="[]"
  if [[ -s "$log_file" ]] && jq empty "$log_file" > /dev/null 2>&1; then
    existing="$(cat "$log_file")"
  fi
  if [[ "$HAS_FLOCK" == "true" ]]; then
    (flock -x -w 10 9 2>/dev/null || true
     printf '%s' "$existing" | jq --argjson e "$entry_json" '. + [$e]' > "$tmp_file" 2>/dev/null && mv "$tmp_file" "$log_file"
    ) 9>"$lock_file"
    rm -f "$lock_file" 2>/dev/null || true
  else
    printf '%s' "$existing" | jq --argjson e "$entry_json" '. + [$e]' > "$tmp_file" 2>/dev/null && mv "$tmp_file" "$log_file"
  fi
}

write_audit() {
  local verdict="$1" reason="${2:-}"
  local log_file="${AUDIT_DIR}/edit-audit-$(get_date_suffix).json"
  mkdir -p "$AUDIT_DIR" 2>/dev/null || true
  local entry
  if [[ "$verdict" == "refused" ]]; then
    entry="$(jq -n --arg ei "$EXECUTION_ID" --arg ag "${AGENT_IDENTITY_TOKEN:-unknown}" --arg p "$TARGET" --arg op 'md-append' --arg v "$verdict" --arg r "$reason" --arg ts "$(get_timestamp)" '{execution_id:$ei,agent:$ag,path:$p,operation:$op,verdict:$v,refusal_reason:$r,timestamp:$ts}' 2>/dev/null)" || return 0
  else
    entry="$(jq -n --arg ei "$EXECUTION_ID" --arg ag "${AGENT_IDENTITY_TOKEN:-unknown}" --arg p "$TARGET" --arg op 'md-append' --arg v "$verdict" --arg ts "$(get_timestamp)" '{execution_id:$ei,agent:$ag,path:$p,operation:$op,verdict:$v,timestamp:$ts}' 2>/dev/null)" || return 0
  fi
  [[ -n "$entry" ]] && atomic_json_append "$log_file" "$entry"
}

# PATH GATE
[[ -z "$TARGET" ]] && { printf 'ERROR: empty path\n' >&2; write_audit "refused" "empty-path"; exit 1; }
if printf '%s' "$TARGET" | grep -qP '\x00' 2>/dev/null; then printf 'ERROR: null byte in path\n' >&2; write_audit "refused" "null-byte-in-path"; exit 1; fi
[[ "$TARGET" == "~"* ]] && { printf 'ERROR: tilde not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "tilde-expansion"; exit 1; }
[[ "$TARGET" == '$'* ]] && { printf 'ERROR: env-var not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "env-var-expansion"; exit 1; }
[[ "$TARGET" == /* ]] && { printf 'ERROR: absolute path not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "absolute-path"; exit 1; }
if [[ "$TARGET" == *"/../"* ]] || [[ "$TARGET" == *"/.." ]] || [[ "$TARGET" == ".."* ]] || printf '%s' "$TARGET" | grep -qE '(^|/)\.\.(/|$)'; then
  printf 'ERROR: traversal detected: %s\n' "$TARGET" >&2; write_audit "refused" "path-traversal"; exit 1
fi
if [[ "$TARGET" != ".claude/memory/"* ]] && [[ "$TARGET" != ".claude/memory" ]]; then
  printf 'ERROR: not in memory allowlist: %s\n' "$TARGET" >&2; write_audit "refused" "not-in-memory-allowlist"; exit 1
fi

TARGET_FULL="${PROJECT_ROOT}/${TARGET}"
[[ -L "$TARGET_FULL" ]] && { printf 'ERROR: symlink refused: %s\n' "$TARGET" >&2; write_audit "refused" "symlink-refused"; exit 1; }
_cp="$TARGET"
while [[ "$_cp" == */* ]]; do
  [[ -L "${PROJECT_ROOT}/${_cp}" ]] && { printf 'ERROR: symlink in path: %s\n' "$TARGET" >&2; write_audit "refused" "symlink-in-path"; exit 1; }
  _cp="${_cp%/*}"
done
[[ ! -f "$TARGET_FULL" ]] && { printf 'ERROR: file not found: %s\n' "$TARGET" >&2; write_audit "refused" "file-not-found"; exit 1; }

# Load content
if [[ "$CONTENT_MODE" == "file" ]]; then
  [[ ! -f "$CONTENT_FILE" ]] && { printf 'ERROR: content-file not found: %s\n' "$CONTENT_FILE" >&2; exit 1; }
  CONTENT=""
  while IFS= read -r _ln || [[ -n "$_ln" ]]; do
    if [[ -z "$CONTENT" ]]; then CONTENT="$_ln"
    else CONTENT="${CONTENT}\n${_ln}"; fi
  done < "$CONTENT_FILE"
fi

# Read current file content (preserve exact bytes)
CURRENT=""
if [[ -s "$TARGET_FULL" ]]; then
  # Read with trailing-newline preservation
  CURRENT="$(cat "$TARGET_FULL"; printf x)"
  CURRENT="${CURRENT%x}"
fi

# Build new content: handle EOL
if [[ -z "$CURRENT" ]]; then
  # Empty file: write content directly
  NEW_CONTENT="$CONTENT"
elif [[ "${CURRENT: -1}" == $'\n' ]]; then
  # File already ends with newline: append directly (no extra blank line)
  NEW_CONTENT="${CURRENT}${CONTENT}"
else
  # File does not end with newline: add one before content
  NEW_CONTENT="${CURRENT}\n${CONTENT}"
fi

# Atomic write
LOCK_FILE="${TARGET_FULL}.teo-ma.lock"
TMP_FILE=""
if [[ "$HAS_FLOCK" == "true" ]]; then
  TMP_FILE="$(mktemp "${TARGET_FULL}.teo-ma.tmp.XXXXXX" 2>/dev/null)" || { printf '%s' "$NEW_CONTENT" > "$TARGET_FULL"; write_audit "applied"; exit 0; }
  _MG_APP_TMPFILES+=("$TMP_FILE")
  (flock -x -w 10 9 2>/dev/null || printf 'WARN: flock timeout\n' >&2
   printf '%s' "$NEW_CONTENT" > "$TMP_FILE"
   mv "$TMP_FILE" "$TARGET_FULL"
  ) 9>"$LOCK_FILE"
  _SUBSHELL_RC=$?
  rm -f "$LOCK_FILE" 2>/dev/null || true
  if [[ "$_SUBSHELL_RC" -ne 0 ]]; then write_audit "refused" "atomic-write-failed"; exit 1; fi
else
  printf 'WARN: flock not available — writing without lock\n' >&2
  TMP_FILE="$(mktemp "${TARGET_FULL}.teo-ma.tmp.XXXXXX" 2>/dev/null)" || true
  if [[ -n "$TMP_FILE" ]]; then
    _MG_APP_TMPFILES+=("$TMP_FILE")
    printf '%s' "$NEW_CONTENT" > "$TMP_FILE"
    mv "$TMP_FILE" "$TARGET_FULL"
  else
    printf '%s' "$NEW_CONTENT" > "$TARGET_FULL"
  fi
fi

write_audit "applied"
exit 0
