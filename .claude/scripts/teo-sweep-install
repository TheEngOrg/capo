#!/usr/bin/env bash
# teo-sweep-install — Run teo-smoke-install for every project in a roster file
#
# Usage: .claude/scripts/teo-sweep-install <roster-file>
#
# Roster file: one absolute project path per line.
# Blank lines and lines starting with '#' are skipped.
# Each line is validated for metacharacter injection before use.
#
# Exit codes:
#   0 = all projects succeeded
#   1 = roster unreadable, validation error, or one or more projects failed

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"

# [1] Arg count guard
if [[ $# -ne 1 ]]; then
    echo "error: usage: teo-sweep-install <roster-file>" >&2
    exit 1
fi

ROSTER="${1}"

# [2] Injection guard on the roster path itself
if [[ "$ROSTER" =~ [';|&$`(){}><'] ]]; then
    echo "error: invalid argument — shell metacharacter detected in roster path: $ROSTER" >&2
    exit 1
fi

# [3] Roster must exist and be readable
if [[ ! -f "$ROSTER" ]]; then
    echo "error: roster file not found — no such file: $ROSTER" >&2
    exit 1
fi
if [[ ! -r "$ROSTER" ]]; then
    echo "error: roster file unreadable: $ROSTER" >&2
    exit 1
fi

SMOKE_INSTALL="$SCRIPT_DIR/teo-smoke-install"
if [[ ! -x "$SMOKE_INSTALL" ]]; then
    echo "error: teo-smoke-install not found or not executable at: $SMOKE_INSTALL" >&2
    exit 1
fi

# [4] Process each line
TOTAL=0
PASSED=0
FAILED=0
FAILURES=""

while IFS= read -r line || [[ -n "$line" ]]; do
    # Trim leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"

    # Skip blank lines and comments
    [[ -z "$line" ]] && continue
    [[ "$line" == "#"* ]] && continue

    TOTAL=$((TOTAL + 1))

    # [5] Injection guard on each roster line
    if [[ "$line" =~ [';|&$`(){}><'] ]]; then
        echo "error: invalid path in roster — shell metacharacter detected: $line" >&2
        exit 1
    fi

    # [6] Backtick guard (backtick is outside the bracket regex above, check separately)
    if [[ "$line" == *'`'* ]]; then
        echo "error: invalid path in roster — shell metacharacter detected: $line" >&2
        exit 1
    fi

    # [7] Run smoke-install for this project
    if "$SMOKE_INSTALL" "$line"; then
        echo "ok: $line"
        PASSED=$((PASSED + 1))
    else
        echo "fail: $line" >&2
        FAILURES="$FAILURES\n  $line"
        FAILED=$((FAILED + 1))
    fi
done < "$ROSTER"

echo "---"
echo "sweep-install: $TOTAL projects processed, $PASSED passed, $FAILED failed"

if [[ $FAILED -gt 0 ]]; then
    echo "Failed projects:" >&2
    printf "%b\n" "$FAILURES" >&2
    exit 1
fi

exit 0
