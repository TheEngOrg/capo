#!/usr/bin/env bash
# ============================================================================
# mg-memory-patch-section — TEO Memory MD Section Patch Tool
# ============================================================================
# Replaces or inserts a named ## section in a .claude/memory/ Markdown file.
# Rejects ambiguous anchors (section header appearing more than once).
# Scope isolation: only the named section is modified.
#
# USAGE
#   mg-memory-patch-section --target <rel-path> --section <header> \
#     --content <text> [--insert-if-missing]
#   mg-memory-patch-section --help | -h
#
# OPTIONS
#   --target <path>       Project-relative path under .claude/memory/
#   --section <header>    Section header WITHOUT ## prefix (e.g., "Disposition")
#                         OR with ## prefix (e.g., "## Disposition")
#   --content <text>      New section content (EXCLUDING the header line)
#   --insert-if-missing   If section not found, append at EOF (default: error)
#   --project-root <path> Override project root
#
# SECTION BOUNDARY
#   A section ends at the next ## heading or EOF.
#   Only the content between the named header and the next ## is replaced.
#
# SECURITY
#   Same path-gate as mg-memory-write. Atomicity: flock + mktemp + mv.
#   EXIT trap unsets bypass token. Every outcome audited.
#
# EXIT CODES
#   0  Applied
#   1  Refused (ambiguous anchor, missing anchor without --insert-if-missing,
#              path safety, etc.)
#   2  Usage error
# ============================================================================

set -uo pipefail

SCRIPT_NAME="mg-memory-patch-section"

TEO_APPLY_EDIT_BYPASS="teo-ae-$$-$(date +%s)"
export TEO_APPLY_EDIT_BYPASS
_MG_PS_TMPFILES=()
trap 'unset TEO_APPLY_EDIT_BYPASS; for _f in "${_MG_PS_TMPFILES[@]:-}"; do rm -f "$_f" 2>/dev/null || true; done' EXIT

HAS_JQ=true
HAS_FLOCK=true
if ! command -v jq > /dev/null 2>&1; then
  printf 'ERROR: jq is required\n' >&2; exit 1
fi
if ! command -v flock > /dev/null 2>&1; then
  HAS_FLOCK=false
  printf 'WARN: flock not available — writing without lock\n' >&2
fi

EXECUTION_ID="$(date +%s)-$$"
get_timestamp() { date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%SZ'; }
get_date_suffix() { date -u '+%Y-%m-%d' 2>/dev/null || date '+%Y-%m-%d'; }

usage() {
  printf 'Usage: %s --target <path> --section <header> --content <text> [--insert-if-missing]\n' "$SCRIPT_NAME"
  printf 'Replace/insert a ## section in a .claude/memory/ Markdown file.\n'
  printf 'Options:\n'
  printf '  --target <path>          Relative path under .claude/memory/\n'
  printf '  --section <header>       Section header (with or without ## prefix)\n'
  printf '  --content <text>         New section body (excluding header line)\n'
  printf '  --content-file <path>    Read section body from file\n'
  printf '  --insert-if-missing      Append section at EOF if not found\n'
  printf '  --project-root <path>    Override project root\n'
  printf '  --help, -h               Show help\n'
}

TARGET=""
SECTION_HEADER=""
SECTION_CONTENT=""
CONTENT_FILE=""
CONTENT_MODE="inline"
INSERT_IF_MISSING=false
PROJECT_ROOT_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    --target)
      [[ $# -lt 2 ]] && { printf 'ERROR: --target requires an argument\n' >&2; exit 2; }
      TARGET="$2"; shift 2 ;;
    --section)
      [[ $# -lt 2 ]] && { printf 'ERROR: --section requires an argument\n' >&2; exit 2; }
      SECTION_HEADER="$2"; shift 2 ;;
    --content)
      [[ $# -lt 2 ]] && { printf 'ERROR: --content requires an argument\n' >&2; exit 2; }
      SECTION_CONTENT="$2"; CONTENT_MODE="inline"; shift 2 ;;
    --content-file)
      [[ $# -lt 2 ]] && { printf 'ERROR: --content-file requires an argument\n' >&2; exit 2; }
      CONTENT_FILE="$2"; CONTENT_MODE="file"; shift 2 ;;
    --insert-if-missing) INSERT_IF_MISSING=true; shift ;;
    --project-root)
      [[ $# -lt 2 ]] && { printf 'ERROR: --project-root requires an argument\n' >&2; exit 2; }
      PROJECT_ROOT_ARG="$2"; shift 2 ;;
    -*) printf 'ERROR: unrecognized flag: %s\n' "$1" >&2; exit 2 ;;
    *) printf 'ERROR: unexpected argument: %s\n' "$1" >&2; exit 2 ;;
  esac
done

[[ -z "$TARGET" ]] && { printf 'ERROR: --target is required\n' >&2; exit 2; }
[[ -z "$SECTION_HEADER" ]] && { printf 'ERROR: --section is required\n' >&2; exit 2; }
# --content can be empty (allowed: replace section with empty body)
[[ "$CONTENT_MODE" == "file" ]] && [[ ! -f "$CONTENT_FILE" ]] && { printf 'ERROR: content-file not found: %s\n' "$CONTENT_FILE" >&2; exit 1; }
if [[ "$CONTENT_MODE" == "file" ]]; then
  SECTION_CONTENT=""
  while IFS= read -r _ln || [[ -n "$_ln" ]]; do
    if [[ -z "$SECTION_CONTENT" ]]; then SECTION_CONTENT="$_ln"
    else SECTION_CONTENT="${SECTION_CONTENT}"$'\n'"$_ln"; fi
  done < "$CONTENT_FILE"
fi

# Normalize section header: ensure it starts with "## "
if [[ "$SECTION_HEADER" == "## "* ]]; then
  FULL_HEADER="$SECTION_HEADER"
elif [[ "$SECTION_HEADER" == "##"* ]]; then
  FULL_HEADER="## ${SECTION_HEADER#\#\#}"
  FULL_HEADER="$(printf '%s' "$FULL_HEADER" | sed 's/^## */## /')"
else
  FULL_HEADER="## $SECTION_HEADER"
fi

if [[ -n "$PROJECT_ROOT_ARG" ]]; then
  PROJECT_ROOT="$PROJECT_ROOT_ARG"
elif [[ -n "${TEO_PROJECT_ROOT:-}" ]]; then
  PROJECT_ROOT="$TEO_PROJECT_ROOT"
elif command -v git > /dev/null 2>&1; then
  PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || printf '%s' "$PWD")"
else
  PROJECT_ROOT="$PWD"
fi

[[ -n "${TEO_AUDIT_DIR:-}" ]] && AUDIT_DIR="$TEO_AUDIT_DIR" || AUDIT_DIR="${PROJECT_ROOT}/.claude/memory/traces"

atomic_json_append() {
  local log_file="$1" entry_json="$2" lock_file tmp_file
  lock_file="${log_file}.lock"
  tmp_file="$(mktemp "${log_file}.tmp.XXXXXX")" || { printf 'WARN: audit temp failed\n' >&2; return 0; }
  _MG_PS_TMPFILES+=("$tmp_file")
  local existing="[]"
  if [[ -s "$log_file" ]] && jq empty "$log_file" > /dev/null 2>&1; then
    existing="$(cat "$log_file")"
  fi
  if [[ "$HAS_FLOCK" == "true" ]]; then
    (flock -x -w 10 9 2>/dev/null || true
     printf '%s' "$existing" | jq --argjson e "$entry_json" '. + [$e]' > "$tmp_file" 2>/dev/null && mv "$tmp_file" "$log_file"
    ) 9>"$lock_file"
    rm -f "$lock_file" 2>/dev/null || true
  else
    printf '%s' "$existing" | jq --argjson e "$entry_json" '. + [$e]' > "$tmp_file" 2>/dev/null && mv "$tmp_file" "$log_file"
  fi
}

write_audit() {
  local verdict="$1" reason="${2:-}"
  local log_file="${AUDIT_DIR}/edit-audit-$(get_date_suffix).json"
  mkdir -p "$AUDIT_DIR" 2>/dev/null || true
  local entry
  if [[ "$verdict" == "refused" ]]; then
    entry="$(jq -n --arg ei "$EXECUTION_ID" --arg ag "${AGENT_IDENTITY_TOKEN:-unknown}" --arg p "$TARGET" --arg op 'md-section-patch' --arg v "$verdict" --arg r "$reason" --arg ts "$(get_timestamp)" '{execution_id:$ei,agent:$ag,path:$p,operation:$op,verdict:$v,refusal_reason:$r,timestamp:$ts}' 2>/dev/null)" || return 0
  else
    entry="$(jq -n --arg ei "$EXECUTION_ID" --arg ag "${AGENT_IDENTITY_TOKEN:-unknown}" --arg p "$TARGET" --arg op 'md-section-patch' --arg v "$verdict" --arg ts "$(get_timestamp)" '{execution_id:$ei,agent:$ag,path:$p,operation:$op,verdict:$v,timestamp:$ts}' 2>/dev/null)" || return 0
  fi
  [[ -n "$entry" ]] && atomic_json_append "$log_file" "$entry"
}

# PATH GATE
[[ -z "$TARGET" ]] && { printf 'ERROR: empty path\n' >&2; write_audit "refused" "empty-path"; exit 1; }
if printf '%s' "$TARGET" | grep -qP '\x00' 2>/dev/null; then printf 'ERROR: null byte in path\n' >&2; write_audit "refused" "null-byte-in-path"; exit 1; fi
[[ "$TARGET" == "~"* ]] && { printf 'ERROR: tilde not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "tilde-expansion"; exit 1; }
[[ "$TARGET" == '$'* ]] && { printf 'ERROR: env-var not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "env-var-expansion"; exit 1; }
[[ "$TARGET" == /* ]] && { printf 'ERROR: absolute path not allowed: %s\n' "$TARGET" >&2; write_audit "refused" "absolute-path"; exit 1; }
if [[ "$TARGET" == *"/../"* ]] || [[ "$TARGET" == *"/.." ]] || [[ "$TARGET" == ".."* ]] || printf '%s' "$TARGET" | grep -qE '(^|/)\.\.(/|$)'; then
  printf 'ERROR: traversal: %s\n' "$TARGET" >&2; write_audit "refused" "path-traversal"; exit 1
fi
if [[ "$TARGET" != ".claude/memory/"* ]] && [[ "$TARGET" != ".claude/memory" ]]; then
  printf 'ERROR: not in memory allowlist: %s\n' "$TARGET" >&2; write_audit "refused" "not-in-memory-allowlist"; exit 1
fi

TARGET_FULL="${PROJECT_ROOT}/${TARGET}"
[[ -L "$TARGET_FULL" ]] && { printf 'ERROR: symlink refused: %s\n' "$TARGET" >&2; write_audit "refused" "symlink-refused"; exit 1; }
_cp="$TARGET"
while [[ "$_cp" == */* ]]; do
  [[ -L "${PROJECT_ROOT}/${_cp}" ]] && { printf 'ERROR: symlink in path: %s\n' "$TARGET" >&2; write_audit "refused" "symlink-in-path"; exit 1; }
  _cp="${_cp%/*}"
done
[[ ! -f "$TARGET_FULL" ]] && { printf 'ERROR: file not found: %s\n' "$TARGET" >&2; write_audit "refused" "file-not-found"; exit 1; }

# Count occurrences of the section header in the file
HEADER_COUNT=0
HEADER_COUNT="$(grep -cF "$FULL_HEADER" "$TARGET_FULL" 2>/dev/null || true)"
HEADER_COUNT="${HEADER_COUNT:-0}"

if [[ "$HEADER_COUNT" -gt 1 ]]; then
  printf 'ERROR: ambiguous anchor — section "%s" appears %d times in %s\n' "$FULL_HEADER" "$HEADER_COUNT" "$TARGET" >&2
  write_audit "refused" "ambiguous-anchor"
  exit 1
fi

if [[ "$HEADER_COUNT" -eq 0 ]]; then
  if [[ "$INSERT_IF_MISSING" == "true" ]]; then
    # Append new section at EOF
    CURRENT_TMPFILE="$(mktemp /tmp/teo-ps-cur.XXXXXX)"
    _MG_PS_TMPFILES+=("$CURRENT_TMPFILE")
    NEW_SECTION_TMPFILE="$(mktemp /tmp/teo-ps-new.XXXXXX)"
    _MG_PS_TMPFILES+=("$NEW_SECTION_TMPFILE")
    # Write section header + blank + content to new_section file
    printf '%s\n\n%s\n' "$FULL_HEADER" "$SECTION_CONTENT" > "$NEW_SECTION_TMPFILE"
    if [[ -s "$TARGET_FULL" ]]; then
      cat "$TARGET_FULL" > "$CURRENT_TMPFILE"
      # Ensure target file ends with newline before appending

      if [[ "$(tail -c 1 "$CURRENT_TMPFILE" | od -An -tx1 | tr -d ' ')" != "0a" ]]; then
        # Does not end with newline — add blank line separator
        printf '\n\n' >> "$CURRENT_TMPFILE"
      else
        printf '\n' >> "$CURRENT_TMPFILE"
      fi
      cat "$NEW_SECTION_TMPFILE" >> "$CURRENT_TMPFILE"
    else
      cat "$NEW_SECTION_TMPFILE" > "$CURRENT_TMPFILE"
    fi
    NEW_CONTENT="$(cat "$CURRENT_TMPFILE"; printf x)"
    NEW_CONTENT="${NEW_CONTENT%x}"
    _MG_PS_DEDUPE=true
  else
    printf 'ERROR: anchor not found — section "%s" not in %s (use --insert-if-missing to append)\n' "$FULL_HEADER" "$TARGET" >&2
    write_audit "refused" "anchor-not-found"
    exit 1
  fi
else
# Replace the existing section using awk  # DEBUGMARK
  # Strategy: collect lines. When we hit the named section header, start
  # replacing. The section ends at the next ## header or EOF.
  CONTENT_TMPFILE="$(mktemp /tmp/teo-ps-content.XXXXXX)"
  _MG_PS_TMPFILES+=("$CONTENT_TMPFILE")
  printf '%s' "$SECTION_CONTENT" > "$CONTENT_TMPFILE"

  NEW_CONTENT="$(awk -v hdr="$FULL_HEADER" -v content_file="$CONTENT_TMPFILE" '
    BEGIN {
      in_section = 0
      replaced = 0
      content = ""
      while ((getline line < content_file) > 0) {
        if (content == "") content = line
        else content = content "\n" line
      }
    }
    # Check if this is the target section header
    $0 == hdr {
      if (replaced == 0) {
        # Emit the header and new content
        print hdr
        if (content != "") {
          print ""
          printf "%s", content
          # Ensure content ends with newline
          if (substr(content, length(content), 1) != "\n") print ""
        }
        in_section = 1
        replaced = 1
        next
      }
    }
    # If in the replaced section, skip lines until next ## heading
    in_section {
      if (/^## /) {
        in_section = 0
        print
      }
      # else: skip (we are replacing this section body)
      next
    }
    { print }
  ' "$TARGET_FULL"; printf x)"
  NEW_CONTENT="${NEW_CONTENT%x}"
fi

# Atomic write
LOCK_FILE="${TARGET_FULL}.teo-ps.lock"
TMP_FILE=""
if [[ "$HAS_FLOCK" == "true" ]]; then
  TMP_FILE="$(mktemp "${TARGET_FULL}.teo-ps.tmp.XXXXXX" 2>/dev/null)" || { printf '%s' "$NEW_CONTENT" > "$TARGET_FULL"; write_audit "applied"; exit 0; }
  _MG_PS_TMPFILES+=("$TMP_FILE")
  (flock -x -w 10 9 2>/dev/null || printf 'WARN: flock timeout\n' >&2
   printf '%s' "$NEW_CONTENT" > "$TMP_FILE"
   mv "$TMP_FILE" "$TARGET_FULL"
  ) 9>"$LOCK_FILE"
  _SUBSHELL_RC=$?
  rm -f "$LOCK_FILE" 2>/dev/null || true
  if [[ "$_SUBSHELL_RC" -ne 0 ]]; then write_audit "refused" "atomic-write-failed"; exit 1; fi
else
  printf 'WARN: flock not available — writing without lock\n' >&2
  TMP_FILE="$(mktemp "${TARGET_FULL}.teo-ps.tmp.XXXXXX" 2>/dev/null)" || true
  if [[ -n "$TMP_FILE" ]]; then
    _MG_PS_TMPFILES+=("$TMP_FILE")
    printf '%s' "$NEW_CONTENT" > "$TMP_FILE"
    mv "$TMP_FILE" "$TARGET_FULL"
  else
    printf '%s' "$NEW_CONTENT" > "$TARGET_FULL"
  fi
fi

write_audit "applied"
exit 0
