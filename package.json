{
  "name": "the-eng-org",
  "version": "1.0.0-pre.0",
  "private": true,
  "description": "TEO — agentic engineering framework + CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheEngOrg/the-eng-org.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "typecheck": "tsc --build",
    "test": "pnpm -r --filter './packages/*' run test",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "clean": "tsc --build --clean && pnpm -r exec rm -rf dist node_modules",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
